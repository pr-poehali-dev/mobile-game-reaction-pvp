# Firebase Web Push — заполни после создания Firebase проекта
# Firebase Console → Project Settings → Cloud Messaging

# Sender ID (числовой, например: 123456789012)
VITE_FCM_SENDER_ID=

# VAPID Public Key (начинается с "B...", ~88 символов)
VITE_FCM_VAPID_KEY=

# Firebase API Key (Project Settings → General → Your apps → Web app → apiKey)
VITE_FCM_API_KEY=
